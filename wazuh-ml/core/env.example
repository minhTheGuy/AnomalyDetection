# Copy this file to .env and fill real credentials

# Wazuh Indexer (OpenSearch)
WAZUH_INDEXER_URL=https://172.16.158.150:9200
WAZUH_INDEX_PATTERN=wazuh-alerts-*
INDEXER_USER=
INDEXER_PASS=

# Wazuh Manager API (push alerts)
WAZUH_MANAGER_API=https://172.16.158.150:55000
WAZUH_MANAGER_USER=
WAZUH_MANAGER_PASS=

# SSL options
# Set VERIFY_SSL=true for production
VERIFY_SSL=false
# CA_BUNDLE_PATH=/path/to/ca.pem  # optional when VERIFY_SSL=true and self-signed certs

# Data paths (optional overrides)
RAW_JSON_PATH=data/security_logs_raw.json
CSV_PATH=data/security_logs.csv
ANALYZED_CSV_PATH=data/security_logs_analyzed.csv
MODEL_PATH=data/model_isoforest.pkl

# Training options
# MODEL_TYPE: ensemble | single (default: ensemble)
MODEL_TYPE=ensemble
# If using single (IsolationForest), normalize input features? (default: true)
SINGLE_IF_NORMALIZE=true


